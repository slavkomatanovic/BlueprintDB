<Window x:Class="Blueprint.App.TabeleNoveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Surplus — nepotrebne tabele i polja"
        Width="920" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="*"/>      <!-- content -->
            <RowDefinition Height="Auto"/>   <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="16,10">
            <StackPanel>
                <TextBlock x:Name="lblTitle" Text="Surplus — nepotrebne tabele i polja"
                           Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock x:Name="lblSubtitle" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content: split na dva DataGrid-a -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>   <!-- splitter -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TabeleNove grid -->
            <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Surplus tabele"
                               Background="#F1F5F9" Padding="8,4" FontWeight="SemiBold" FontSize="11" Foreground="#475569"/>
                    <DataGrid x:Name="dgTabele"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="DgTabele_SelectionChanged"
                              CanUserResizeRows="False"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F8FAFC"
                              RowBackground="White"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Naziv tabele" Binding="{Binding Nazivtabele}" Width="*"/>
                            <DataGridTextColumn Header="Tip" Binding="{Binding TipOpis}" Width="120"/>
                            <DataGridTextColumn Header="Verzija" Binding="{Binding Verzija}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#E2E8F0"/>

            <!-- KoloneNove grid -->
            <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" x:Name="lblKoloneHeader"
                               Text="Kolone odabrane tabele"
                               Background="#F1F5F9" Padding="8,4" FontWeight="SemiBold" FontSize="11" Foreground="#475569"/>
                    <DataGrid x:Name="dgKolone"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserResizeRows="False"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F8FAFC"
                              RowBackground="White"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Naziv kolone" Binding="{Binding Nazivkolone}" Width="*"/>
                            <DataGridTextColumn Header="Tip podatka" Binding="{Binding Tippodatka}" Width="120"/>
                            <DataGridTextColumn Header="Veličina" Binding="{Binding Fieldsize}" Width="80"/>
                            <DataGridTextColumn Header="Null" Binding="{Binding Allownull}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <TextBlock x:Name="lblStatus" DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="#64748B" FontSize="11"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnIzbrisi" Content="Izbriši" Width="90" Margin="0,0,6,0"
                            Click="BtnIzbrisi_Click"
                            Background="#DC2626" Foreground="White" BorderThickness="0"
                            Padding="0,6" FontWeight="SemiBold"/>
                    <Button x:Name="btnIzbrisiSve" Content="Izbriši sve" Width="100" Margin="0,0,6,0"
                            Click="BtnIzbrisiSve_Click"
                            Background="#9333EA" Foreground="White" BorderThickness="0"
                            Padding="0,6" FontWeight="SemiBold"/>
                    <Button x:Name="btnOcistiListu" Content="Očisti listu" Width="100" Margin="0,0,16,0"
                            Click="BtnOcistiListu_Click"
                            Background="#0F172A" Foreground="White" BorderThickness="0"
                            Padding="0,6" FontWeight="SemiBold"/>
                    <Button x:Name="btnZatvori" Content="Zatvori" Width="80"
                            Click="BtnZatvori_Click"
                            Background="#475569" Foreground="White" BorderThickness="0"
                            Padding="0,6" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
