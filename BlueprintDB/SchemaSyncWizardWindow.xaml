<Window x:Class="Blueprint.App.SchemaSyncWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Tag="FORM_SCHEMA_SYNC"
        Title="Schema Sync Wizard"
        Height="500" Width="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="185"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#1E1B4B">
            <StackPanel Margin="0,28,0,0">
                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           HorizontalAlignment="Center" Foreground="#A5B4FC" Margin="0,0,0,6"/>
                <TextBlock Text="Blueprint" FontSize="16" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock FontSize="10" Foreground="#A5B4FC" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Padding="16,4,16,32"
                           Text="Schema Sync Wizard"/>

                <StackPanel Margin="26,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot1" Width="24" Height="24" Fill="#6366F1"/>
                            <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl1" Text="Program" Foreground="White"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <Border Width="2" Height="20" Background="#312E81" HorizontalAlignment="Left" Margin="11,2,0,2"/>

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot2" Width="24" Height="24" Fill="#4B5563"/>
                            <TextBlock Text="2" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl2" Text="Backend" Foreground="#A5B4FC"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <Border Width="2" Height="20" Background="#312E81" HorizontalAlignment="Left" Margin="11,2,0,2"/>

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot3" Width="24" Height="24" Fill="#4B5563"/>
                            <TextBlock Text="3" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl3" Text="Sync" Foreground="#A5B4FC"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Content area ─────────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="28,28,28,12">

                <!-- Page 1: Program -->
                <StackPanel x:Name="page1">
                    <TextBlock Text="Select a program" FontSize="20" FontWeight="SemiBold"
                               Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,24"
                               Text="The wizard will compare this program's stored schema against a live database and show you what has changed."/>
                    <TextBlock Text="Program" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbProgram" Padding="6,4" FontSize="13"
                              DisplayMemberPath="Nazivprograma" SelectedValuePath="Idprograma"/>
                </StackPanel>

                <!-- Page 2: Backend -->
                <StackPanel x:Name="page2" Visibility="Collapsed">
                    <TextBlock Text="Connect to live database" FontSize="20" FontWeight="SemiBold"
                               Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,20"
                               Text="This is the live database to compare against. Blueprint will read its structure but will not write anything to it."/>
                    <TextBlock Text="Database type" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbBackendType" Padding="6,4" FontSize="13"
                              SelectionChanged="CbBackendType_SelectionChanged"/>

                    <TextBlock x:Name="lblPath" Text="File path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4"/>
                    <Grid x:Name="rowPath">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtPath" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5" Click="BtnBrowse_Click" Background="#64748B"/>
                    </Grid>
                    <TextBlock x:Name="lblFolder" Text="Folder path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <Grid x:Name="rowFolder" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtFolder" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5"
                                Click="BtnBrowseFolder_Click" Background="#64748B"/>
                    </Grid>
                    <TextBlock x:Name="lblCs" Text="Connection string" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <TextBox x:Name="txtCs" Padding="7,5" FontSize="12"
                             BorderBrush="#D1D5DB" TextWrapping="Wrap" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Page 3: Sync diff + apply -->
                <Grid x:Name="page3" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="lblSyncTitle" Text="Analysing schema…"
                               FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" x:Name="lblSyncSub"
                               Text="Comparing Blueprint metadata against the live database."
                               TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,8"/>

                    <!-- Diff list — each item coloured in code-behind -->
                    <ListBox Grid.Row="2" x:Name="lstDiff" FontSize="11" FontFamily="Consolas"
                             BorderBrush="#E5E7EB" Margin="0,0,0,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                    <!-- Apply button (shown after analysis) -->
                    <Button Grid.Row="3" x:Name="btnApply" Content="Apply Changes"
                            Visibility="Collapsed" HorizontalAlignment="Left"
                            Padding="16,6" Margin="0,0,0,8"
                            Background="#9333EA"
                            Click="BtnApply_Click"/>

                    <!-- Result summary -->
                    <Border Grid.Row="4" x:Name="pnlSummary" Visibility="Collapsed"
                            Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1"
                            CornerRadius="4" Padding="12,8">
                        <TextBlock x:Name="lblSummary" FontSize="12" Foreground="#166534"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Grid>

            <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left"
                            Width="80" Click="BtnCancel_Click" Background="#64748B"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnBack" Content="← Back" Width="80" Margin="0,0,8,0"
                                IsEnabled="False" Click="BtnBack_Click" Background="#475569"/>
                        <Button x:Name="btnNext" Content="Next →" Width="90" Click="BtnNext_Click" Background="#2563EB"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
