<Window x:Class="Blueprint.App.BatchSchemaSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Tag="FORM_BATCH_SYNC"
        Title="Batch Schema Sync" Height="680" Width="820"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Program + Options -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Target program" Tag="GRP_PROGRAM_IZBOR">
                <Grid Margin="6,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Program:" Tag="LBL_ODABRANI_PROGRAM"
                           Grid.Column="0" VerticalAlignment="Center" Padding="0,0,8,0"/>
                    <ComboBox x:Name="cbProgrami" Grid.Column="1"
                              DisplayMemberPath="Nazivprograma"
                              SelectedValuePath="Idprograma"
                              Height="26"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Options" Tag="GRP_OPCIJE">
                <StackPanel Margin="6,4">
                    <CheckBox x:Name="chkBrisiNepotrebno" Tag="CHK_BRISI_NEPOTREBNO"
                              Content="Auto-delete redundant tables and columns"
                              Margin="0,2"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Backend list header -->
        <TextBlock Grid.Row="1" Text="Backend databases" FontWeight="SemiBold"
                   Margin="0,0,0,3" Foreground="#374151"/>

        <!-- Backend file list -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="3">
                <ListBox x:Name="lstBackends" SelectionMode="Extended"
                         FontFamily="Consolas" FontSize="11"
                         BorderThickness="0"/>
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Top" Width="110">
                <Button Content="Add Files…" Tag="CMD_DODAJ_FAJLOVE"
                        Margin="0,0,0,4" Click="BtnAdd_Click" Background="#15803D"
                        ToolTip="Add SQLite database files to the batch sync queue"/>
                <Button Content="Remove" Tag="CMD_UKLONI"
                        Click="BtnRemove_Click" Background="#64748B"
                        ToolTip="Remove the selected file from the list"/>
            </StackPanel>
        </Grid>

        <!-- Results header -->
        <TextBlock Grid.Row="3" Text="Results" FontWeight="SemiBold"
                   Margin="0,8,0,3" Foreground="#374151"/>

        <!-- Results grid -->
        <DataGrid Grid.Row="4" x:Name="dgResults"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0" CanUserReorderColumns="False"
                  CanUserResizeRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Path"    Binding="{Binding Path}"       Width="*"   MinWidth="160"/>
                <DataGridTextColumn Header="Status"  Binding="{Binding StatusText}"  Width="200" MinWidth="80"/>
                <DataGridTextColumn Header="+Tables" Binding="{Binding TablesCreated}" Width="65"/>
                <DataGridTextColumn Header="+Cols"   Binding="{Binding ColumnsAdded}"  Width="55"/>
                <DataGridTextColumn Header="+FKs"    Binding="{Binding FksAdded}"      Width="50"/>
                <DataGridTextColumn Header="-Tables" Binding="{Binding TablesDropped}" Width="65"/>
                <DataGridTextColumn Header="-Cols"   Binding="{Binding ColumnsDropped}" Width="55"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Success}" Value="False">
                            <Setter Property="Background" Value="#FFF1F2"/>
                            <Setter Property="Foreground" Value="#7F1D1D"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Bottom bar -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Progress -->
            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                <ProgressBar x:Name="progressBar" Height="6" Minimum="0" Maximum="100"
                             Margin="0,0,0,4" Visibility="Collapsed"/>
                <TextBlock x:Name="lblProgress" FontSize="11" Foreground="#6B7280"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="btnSyncAll" Content="Sync All" Tag="CMD_SYNC_SVE"
                        Width="90" Margin="0,0,6,0"
                        Click="BtnSyncAll_Click" Background="#7C3AED"
                        ToolTip="Run Schema Sync for all databases in the list"/>
                <Button Content="Close" Tag="CMD_ZATVORI"
                        Width="80" IsCancel="True"
                        Click="BtnZatvori_Click" Background="#64748B"
                        ToolTip="Close this window"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
