<Window x:Class="Blueprint.App.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activate Blueprint Pro"
        Width="520" Height="480"
        MinWidth="420" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Activate Blueprint Pro" Foreground="White"
                           FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,0">

                <!-- Pro features list -->
                <Border Background="#EFF6FF" CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Blueprint Pro includes:" FontWeight="SemiBold"
                                   FontSize="12" Foreground="#1E40AF" Margin="0,0,0,10"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#16A34A" Margin="0,1,6,0"/>
                                <TextBlock Text="Schema Import on all backends (SQLite &amp; Access free)"
                                           FontSize="12" Foreground="#1E3A5F"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#16A34A" Margin="0,1,6,0"/>
                                <TextBlock Text="Schema Sync on all backends (SQLite &amp; Access free)"
                                           FontSize="12" Foreground="#1E3A5F"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#16A34A" Margin="0,1,6,0"/>
                                <TextBlock Text="Unlimited Transfer Data Wizard runs (5 free runs included)"
                                           FontSize="12" Foreground="#1E3A5F"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="#16A34A" Margin="0,1,6,0"/>
                                <TextBlock Text="All backends: MySQL, SQL Server, PostgreSQL, Firebird, Oracle, DB2"
                                           FontSize="12" Foreground="#1E3A5F"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- License key input -->
                <TextBlock Text="License key:" FontSize="12" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtKey" Grid.Column="0"
                             FontFamily="Consolas" FontSize="13"
                             Padding="8,6" BorderBrush="#CBD5E1"
                             BorderThickness="1" VerticalContentAlignment="Center"
                             CharacterCasing="Upper"
                             KeyDown="TxtKey_KeyDown"/>
                    <Button Grid.Column="1" x:Name="btnActivate" Content="Activate"
                            Width="90" Margin="8,0,0,0"
                            Background="#1D4ED8" Foreground="White"
                            FontWeight="SemiBold" Padding="0,6"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnActivate_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="bd" Property="Background" Value="#93C5FD"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Status message -->
                <Border x:Name="pnlStatus" Visibility="Collapsed"
                        CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                    <TextBlock x:Name="lblStatus" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Deactivate link (shown only when Pro active) -->
                <StackPanel x:Name="pnlDeactivate" Visibility="Collapsed"
                            Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Active key: " FontSize="11" Foreground="#6B7280"/>
                    <TextBlock x:Name="lblActiveKey" FontSize="11" Foreground="#374151"
                               FontFamily="Consolas"/>
                    <TextBlock Text=" · " FontSize="11" Foreground="#6B7280"/>
                    <TextBlock Text="Deactivate" FontSize="11" Foreground="#DC2626"
                               Cursor="Hand" TextDecorations="Underline"
                               MouseLeftButtonUp="LblDeactivate_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <TextBlock VerticalAlignment="Center">
                    <Hyperlink x:Name="lnkBuy" NavigateUri="https://blueprintdb.io"
                               RequestNavigate="LnkBuy_RequestNavigate">
                        <TextBlock Text="Get a Pro license at blueprintdb.io"
                                   FontSize="11" Foreground="#0891B2"/>
                    </Hyperlink>
                </TextBlock>
                <Button Content="Close" Width="80" HorizontalAlignment="Right"
                        Background="#475569" Foreground="White"
                        BorderThickness="0" Padding="0,5"
                        Cursor="Hand" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#334155"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
