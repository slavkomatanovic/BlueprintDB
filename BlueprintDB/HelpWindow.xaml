<Window x:Class="Blueprint.App.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Tag="FORM_HELP"
        Title="Help"
        Width="920" Height="620"
        MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F8FAFC">

    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Tag="FORM_HELP" Text="Help" Foreground="White"
                           FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content: sidebar + main panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#1E293B">
                <ListBox x:Name="lstTopics"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="LstTopics_SelectionChanged"
                         Padding="0,8,0,8">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"          Value="18,7"/>
                            <Setter Property="Foreground"       Value="#94A3B8"/>
                            <Setter Property="FontSize"         Value="12"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#334155"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#273449"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <!-- Main content -->
            <ScrollViewer Grid.Column="1" x:Name="scrollContent"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="36,28,36,28">
                <StackPanel x:Name="pnlContent" MaxWidth="640"/>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0" Padding="10,6">
            <Button Tag="CMD_ZATVORI" Content="Close" Width="80"
                    HorizontalAlignment="Right"
                    Background="#475569" Click="BtnClose_Click"/>
        </Border>
    </Grid>
</Window>
