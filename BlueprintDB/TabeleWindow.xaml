<Window x:Class="Blueprint.App.TabeleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Tag="FORM_TABELE"
        Title="Tables" Height="550" Width="750"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Label Content="Program:" Tag="LBL_PROGRAM" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbProgrami" Width="250" DisplayMemberPath="Nazivprograma"
                      SelectedValuePath="Idprograma" SelectionChanged="cbProgrami_SelectionChanged"/>
        </StackPanel>

        <DataGrid x:Name="dgTabele" Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  IsReadOnly="True"
                  SelectionChanged="dgTabele_SelectionChanged"
                  MouseDoubleClick="dgTabele_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="[HDR_ID]"            Binding="{Binding Idtabele}"    Width="50"/>
                <DataGridTextColumn Header="[HDR_NAZIV_TABELE]"  Binding="{Binding Nazivtabele}" Width="*"/>
                <DataGridTextColumn Header="[HDR_VERZIJA]"       Binding="{Binding Verzija}"     Width="80"/>
                <DataGridTextColumn Header="[HDR_SID]"           Binding="{Binding Sid}"         Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="2" Header="Add / Edit" Tag="GRP_UNOS_IZMJENA" Margin="0,6,0,6">
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <Label Content="Table name:" Tag="LBL_NAZIV_TABELE" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtNazivTabele" Grid.Column="1" Margin="0,3,6,3" Padding="3"/>
                <Label Content="Version:" Tag="LBL_VERZIJA" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="txtVerzija" Grid.Column="3" Margin="0,3,6,3" Padding="3"/>
                <Label Content="SID:" Tag="LBL_SID" Grid.Column="4" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSid" Grid.Column="5" Margin="0,3,0,3" Padding="3"/>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="3">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button x:Name="btnImport" Content="Import" Tag="CMD_IMPORT" Width="80" Margin="4,0" Click="BtnImport_Click" Background="#0369A1"
                        ToolTip="Open the Schema Import Wizard to import tables from a live database"/>
                <Button Content="Reset"  Tag="CMD_RESET"  Width="80" Margin="4,0" Click="BtnReset_Click" Background="#64748B"
                        ToolTip="Clear the filter and reload all tables for the selected program"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="New"       Tag="CMD_NOVI"       Width="80" Margin="4,0" Click="BtnNovi_Click"    Background="#1E3A5F"  ToolTip="Clear the form to add a new table"/>
                <Button Content="Save"      Tag="CMD_SACUVAJ"    Width="80" Margin="4,0" Click="BtnSacuvaj_Click" Background="#15803D"  ToolTip="Save the current table (insert or update)"/>
                <Button Content="Delete"    Tag="CMD_OBRISI"     Width="80" Margin="4,0" Click="BtnObrisi_Click"  Background="#DC2626"  ToolTip="Delete the selected table"/>
                <Button Content="Columns →" Tag="CMD_KOLONE_NAV" Width="90" Margin="4,0" Click="BtnKolone_Click"  Background="#2563EB"  ToolTip="Open the Columns window for the selected table"/>
                <Button Content="Close"     Tag="CMD_ZATVORI"    Width="80" Margin="4,0" Click="BtnZatvori_Click" Background="#475569"  ToolTip="Close this window"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
