<Window x:Class="Blueprint.App.ExportSchemaSqlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Schema as SQL"
        Width="400" Height="270"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="20,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="#60A5FA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Export Schema as SQL" Foreground="White"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="24,18,24,0">

            <TextBlock Text="Program:" FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,6"/>
            <ComboBox x:Name="cbProgram"
                      DisplayMemberPath="Nazivprograma"
                      SelectedValuePath="Idprograma"
                      Padding="6,5" FontSize="13" Margin="0,0,0,14"/>

            <TextBlock Text="Target SQL dialect:" FontSize="12" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,6"/>
            <ComboBox x:Name="cbTarget" Padding="6,5" FontSize="13">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            <Border Background="#7C3AED" CornerRadius="3" Padding="5,1"
                                    Margin="7,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding Converter={StaticResource BackendProConverter}}">
                                <TextBlock Text="PRO" FontSize="9" FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnExport" Content="Export…"
                        Width="90" Margin="0,0,8,0"
                        Background="#0891B2" Foreground="White"
                        FontWeight="SemiBold" Padding="0,6"
                        BorderThickness="0" Cursor="Hand"
                        IsDefault="True" Click="BtnExport_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#0E7490"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Cancel" Width="80"
                        Background="#475569" Foreground="White"
                        Padding="0,6" BorderThickness="0" Cursor="Hand"
                        IsCancel="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#334155"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
