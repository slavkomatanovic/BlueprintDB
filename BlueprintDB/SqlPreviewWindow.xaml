<Window x:Class="Blueprint.App.SqlPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Preview"
        Width="620" Height="400"
        MinWidth="400" MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#0F172A"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x26A0;" Foreground="#F59E0B" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="SQL Preview" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="Pregled SQL koda koji će biti izvršen na backend bazi" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- SQL TextBox -->
        <Border Grid.Row="1" Margin="12,12,12,0" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
            <TextBox x:Name="txtSql"
                     IsReadOnly="True"
                     FontFamily="Consolas, Courier New"
                     FontSize="13"
                     Foreground="#E2E8F0"
                     Background="#0F172A"
                     BorderThickness="0"
                     Padding="12"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"/>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" Padding="12,10" Background="#0F172A">
            <DockPanel>
                <TextBlock x:Name="lblHint" DockPanel.Dock="Left" Foreground="#64748B" FontSize="10"
                           VerticalAlignment="Center" Text="Kôd možete kopirati prije izvršenja."/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnIzvrsi" Content="Izvrši" Width="90" Margin="0,0,8,0"
                            Click="BtnIzvrsi_Click"
                            Background="#DC2626"/>
                    <Button x:Name="btnOtkazi" Content="Otkaži" Width="80"
                            Click="BtnOtkazi_Click"
                            Background="#475569"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
