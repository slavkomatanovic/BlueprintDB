<Window x:Class="Blueprint.App.TransferWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Tag="FORM_TRANSFER_WIZARD"
        Title="Transfer Data Wizard"
        Height="530" Width="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="185"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#0C2D48">
            <StackPanel Margin="0,28,0,0">
                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           HorizontalAlignment="Center" Foreground="#38BDF8" Margin="0,0,0,6"/>
                <TextBlock Text="Blueprint" FontSize="16" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock FontSize="10" Foreground="#7DD3FC" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Padding="16,4,16,32"
                           Text="Transfer Data Wizard"/>

                <StackPanel Margin="26,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot1" Width="24" Height="24" Fill="#0EA5E9"/>
                            <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl1" Text="Program" Foreground="White"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <Border Width="2" Height="20" Background="#164E63" HorizontalAlignment="Left" Margin="11,2,0,2"/>

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot2" Width="24" Height="24" Fill="#4B5563"/>
                            <TextBlock Text="2" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl2" Text="Source" Foreground="#7DD3FC"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <Border Width="2" Height="20" Background="#164E63" HorizontalAlignment="Left" Margin="11,2,0,2"/>

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot3" Width="24" Height="24" Fill="#4B5563"/>
                            <TextBlock Text="3" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl3" Text="Target" Foreground="#7DD3FC"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <Border Width="2" Height="20" Background="#164E63" HorizontalAlignment="Left" Margin="11,2,0,2"/>

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot4" Width="24" Height="24" Fill="#4B5563"/>
                            <TextBlock Text="4" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl4" Text="Transfer" Foreground="#7DD3FC"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Content area ─────────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="28,28,28,12">

                <!-- Page 1: Program -->
                <StackPanel x:Name="page1">
                    <TextBlock Text="Select a program" FontSize="20" FontWeight="SemiBold"
                               Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,24"
                               Text="Choose the program whose table list will guide the transfer. Only tables registered in Blueprint will be transferred."/>
                    <TextBlock Text="Program" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbProgram" Padding="6,4" FontSize="13"
                              DisplayMemberPath="Nazivprograma" SelectedValuePath="Idprograma"/>
                </StackPanel>

                <!-- Page 2: Source -->
                <StackPanel x:Name="page2" Visibility="Collapsed">
                    <TextBlock Text="Source database" FontSize="20" FontWeight="SemiBold"
                               Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,20"
                               Text="Data will be read from this database."/>
                    <TextBlock Text="Database type" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbSrcType" Padding="6,4" FontSize="13"
                              SelectionChanged="CbSrcType_SelectionChanged"/>

                    <TextBlock x:Name="lblSrcPath" Text="File path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4"/>
                    <Grid x:Name="rowSrcPath">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtSrcPath" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5"
                                Click="BtnSrcBrowse_Click" Background="#64748B"/>
                    </Grid>
                    <TextBlock x:Name="lblSrcFolder" Text="Folder path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <Grid x:Name="rowSrcFolder" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtSrcFolder" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5"
                                Click="BtnSrcBrowseFolder_Click" Background="#64748B"/>
                    </Grid>
                    <TextBlock x:Name="lblSrcCs" Text="Connection string" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <TextBox x:Name="txtSrcCs" Padding="7,5" FontSize="12"
                             BorderBrush="#D1D5DB" TextWrapping="Wrap" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Page 3: Target -->
                <StackPanel x:Name="page3" Visibility="Collapsed">
                    <TextBlock Text="Target database" FontSize="20" FontWeight="SemiBold"
                               Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,20"
                               Text="Data will be written to this database. Existing rows in each table will be deleted before inserting."/>
                    <TextBlock Text="Database type" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbTgtType" Padding="6,4" FontSize="13"
                              SelectionChanged="CbTgtType_SelectionChanged"/>

                    <TextBlock x:Name="lblTgtPath" Text="File path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4"/>
                    <Grid x:Name="rowTgtPath">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtTgtPath" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5"
                                Click="BtnTgtBrowse_Click" Background="#64748B"/>
                    </Grid>
                    <TextBlock x:Name="lblTgtFolder" Text="Folder path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <Grid x:Name="rowTgtFolder" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtTgtFolder" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5"
                                Click="BtnTgtBrowseFolder_Click" Background="#64748B"/>
                    </Grid>
                    <TextBlock x:Name="lblTgtCs" Text="Connection string" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <TextBox x:Name="txtTgtCs" Padding="7,5" FontSize="12"
                             BorderBrush="#D1D5DB" TextWrapping="Wrap" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Page 4: Transfer progress -->
                <Grid x:Name="page4" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="lblTitle" Text="Transferring data…"
                               FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" x:Name="lblSub"
                               Text="Copying rows from source to target database."
                               TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,10"/>
                    <ProgressBar Grid.Row="2" x:Name="progressBar" Height="8"
                                 Minimum="0" Maximum="100" Foreground="#0EA5E9"
                                 Background="#E5E7EB" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="3" x:Name="lstLog" FontSize="11" Foreground="#374151"
                             BorderBrush="#E5E7EB" Margin="0,0,0,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    <Border Grid.Row="4" x:Name="pnlSummary" Visibility="Collapsed"
                            Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1"
                            CornerRadius="4" Padding="12,8">
                        <TextBlock x:Name="lblSummary" FontSize="12" Foreground="#166534"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Grid>

            <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left"
                            Width="80" Click="BtnCancel_Click" Background="#64748B"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnBack" Content="← Back" Width="80" Margin="0,0,8,0"
                                IsEnabled="False" Click="BtnBack_Click" Background="#475569"/>
                        <Button x:Name="btnNext" Content="Next →" Width="90" Click="BtnNext_Click" Background="#2563EB"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
