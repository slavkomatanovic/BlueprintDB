<Window x:Class="Blueprint.App.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Tag="FORM_LOG"
        Title="Log"
        Width="1000" Height="640"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F8FAFC">

    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- filter bar -->
            <RowDefinition Height="*"/>     <!-- grid -->
            <RowDefinition Height="5"/>     <!-- splitter -->
            <RowDefinition Height="130"/>   <!-- detail panel -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Tag="FORM_LOG" Text="Log" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock x:Name="lblCount" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="10,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Tag="CMD_LOG_OSVJEZI" Content="Refresh" Width="80" Margin="0,0,6,0"
                            Background="#0369A1" Click="BtnRefresh_Click"/>
                    <Button Tag="CMD_LOG_OCISTI" Content="Clear log" Width="90" Margin="0,0,6,0"
                            Background="#DC2626" Click="BtnClear_Click"/>
                    <Button Tag="CMD_ZATVORI" Content="Close" Width="80"
                            Background="#475569" Click="BtnZatvori_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Tag="LBL_LOG_NIVO" Text="Level:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#475569" FontSize="12"/>
                    <ComboBox x:Name="cbNivo" Width="110" Height="26" Margin="0,0,14,0"
                              SelectionChanged="Filter_Changed"/>
                    <TextBlock Tag="LBL_LOG_KATEGORIJA" Text="Category:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#475569" FontSize="12"/>
                    <ComboBox x:Name="cbKategorija" Width="140" Height="26" Margin="0,0,14,0"
                              SelectionChanged="Filter_Changed"/>
                    <TextBlock Tag="LBL_LOG_PRETRAGA" Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#475569" FontSize="12"/>
                    <TextBox x:Name="txtSearch" Width="180" Height="26" Padding="4,3"
                             TextChanged="Filter_Changed"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Log DataGrid -->
        <DataGrid x:Name="dgLog" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgLog_SelectionChanged"
                  CanUserResizeRows="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8FAFC"
                  RowBackground="White"
                  HeadersVisibility="Column"
                  BorderThickness="0"
                  FontSize="11"
                  RowHeight="22">
            <DataGrid.Columns>
                <DataGridTextColumn Header="[HDR_LOG_DATUM]"
                                    Binding="{Binding Datumvrijeme, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}"
                                    Width="148" IsReadOnly="True"/>
                <DataGridTextColumn Header="[HDR_LOG_NIVO]"      Binding="{Binding Nivo}"       Width="70"/>
                <DataGridTextColumn Header="[HDR_LOG_KATEGORIJA]" Binding="{Binding Kategorija}" Width="110"/>
                <DataGridTextColumn Header="[HDR_LOG_PORUKA]"    Binding="{Binding Poruka}"      Width="*"/>
                <DataGridTextColumn Header="[HDR_LOG_BACKEND]"   Binding="{Binding Backend}"     Width="90"/>
                <DataGridTextColumn Header="[HDR_LOG_PROGRAM]"   Binding="{Binding Idprogram}"   Width="65"/>
                <DataGridTextColumn Header="[HDR_LOG_KORISNIK]"  Binding="{Binding Korisnik}"    Width="90"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Nivo}" Value="ERROR">
                            <Setter Property="Foreground" Value="#DC2626"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Nivo}" Value="WARNING">
                            <Setter Property="Foreground" Value="#D97706"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Nivo}" Value="SQL">
                            <Setter Property="Foreground" Value="#0369A1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Nivo}" Value="INFO">
                            <Setter Property="Foreground" Value="#374151"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#E2E8F0"/>

        <!-- Detail panel -->
        <Grid Grid.Row="4" Margin="8,4,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="3">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Tag="LBL_LOG_DETALJI" Text="Details / Stack trace"
                               Background="#F1F5F9" Padding="6,3"
                               FontSize="10" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBox x:Name="txtDetalji" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="10"
                             Background="White" BorderThickness="0" Padding="6"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="3">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Tag="LBL_LOG_SQLKOD" Text="SQL code"
                               Background="#F1F5F9" Padding="6,3"
                               FontSize="10" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBox x:Name="txtSqlKod" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="10"
                             Background="White" BorderThickness="0" Padding="6"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="5" Background="#F1F5F9" BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0" Padding="10,5">
            <TextBlock x:Name="lblStatus" FontSize="10" Foreground="#64748B" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
