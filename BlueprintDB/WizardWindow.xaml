<Window x:Class="Blueprint.App.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Tag="FORM_WIZARD"
        Title="Schema Import Wizard"
        Height="500" Width="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="185"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#1E3A5F">
            <StackPanel Margin="0,28,0,0">

                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           HorizontalAlignment="Center" Foreground="#60A5FA" Margin="0,0,0,6"/>
                <TextBlock Text="Blueprint" FontSize="16" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock FontSize="10" Foreground="#93C5FD" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Padding="16,4,16,32"
                           Text="Schema Import Wizard"/>

                <!-- Step indicators -->
                <StackPanel Margin="26,0,16,0">

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot1" Width="24" Height="24" Fill="#3B82F6"/>
                            <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl1" Text="Program" Foreground="White"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>

                    <Border Width="2" Height="20" Background="#2D4E6B"
                            HorizontalAlignment="Left" Margin="11,2,0,2"/>

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot2" Width="24" Height="24" Fill="#4B5563"/>
                            <TextBlock Text="2" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl2" Text="Backend" Foreground="#93C5FD"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>

                    <Border Width="2" Height="20" Background="#2D4E6B"
                            HorizontalAlignment="Left" Margin="11,2,0,2"/>

                    <StackPanel Orientation="Horizontal">
                        <Grid Width="26" Margin="0,0,10,0">
                            <Ellipse x:Name="dot3" Width="24" Height="24" Fill="#4B5563"/>
                            <TextBlock Text="3" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="lbl3" Text="Import" Foreground="#93C5FD"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Content area ─────────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Step pages — all stacked in the same cell; only one visible at a time -->
            <Grid Grid.Row="0" Margin="28,28,28,12">

                <!-- Page 1: Name your program -->
                <StackPanel x:Name="page1">
                    <TextBlock Text="Name your program" FontSize="20" FontWeight="SemiBold"
                               Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,20"
                               Text="In Blueprint, each database is called a 'Program'. Give it a name, or select an existing program to reimport its schema."/>

                    <!-- New program -->
                    <TextBlock Text="New program name" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtProgramName" Padding="7,5" FontSize="13" BorderBrush="#D1D5DB"
                             TextChanged="TxtProgramName_TextChanged"/>

                    <TextBlock Text="Version  (optional)" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,12,0,4"/>
                    <TextBox x:Name="txtVersion" Padding="7,5" FontSize="13" BorderBrush="#D1D5DB"/>

                    <!-- Divider -->
                    <Grid Margin="0,18,0,14">
                        <Separator/>
                        <TextBlock Text=" or reimport an existing program " Background="White"
                                   Foreground="#9CA3AF" FontSize="11"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Padding="6,0"/>
                    </Grid>

                    <!-- Existing program -->
                    <TextBlock Text="Existing program" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbExistingProgram"
                              DisplayMemberPath="Nazivprograma"
                              SelectedValuePath="Idprograma"
                              Padding="6,4" FontSize="13"
                              SelectionChanged="CbExistingProgram_SelectionChanged"/>
                    <Border x:Name="pnlReimportWarning" Visibility="Collapsed"
                            Background="#FEF9C3" BorderBrush="#FDE047" BorderThickness="1"
                            CornerRadius="3" Padding="10,7" Margin="0,8,0,0">
                        <TextBlock FontSize="11" Foreground="#713F12" TextWrapping="Wrap"
                                   Text="⚠ All existing tables and columns for this program will be deleted and reimported from the source database."/>
                    </Border>
                </StackPanel>

                <!-- Page 2: Select backend -->
                <StackPanel x:Name="page2" Visibility="Collapsed">
                    <TextBlock Text="Select the source database" FontSize="20" FontWeight="SemiBold"
                               Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,20"
                               Text="Blueprint will read the table and column structure from this database and store it as metadata."/>

                    <TextBlock Text="Database type" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cbBackendType" Padding="6,4" FontSize="13"
                              SelectionChanged="CbBackendType_SelectionChanged"/>

                    <!-- File path (SQLite, Access, Firebird) -->
                    <TextBlock x:Name="lblPath" Text="File path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4"/>
                    <Grid x:Name="rowPath">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtPath" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5" Click="BtnBrowse_Click" Background="#64748B"/>
                    </Grid>

                    <!-- Folder path (dBase) -->
                    <TextBlock x:Name="lblFolder" Text="Folder path" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <Grid x:Name="rowFolder" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtFolder" Grid.Column="0" Padding="7,5" FontSize="13"
                                 BorderBrush="#D1D5DB" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Browse…" Padding="12,5"
                                Click="BtnBrowseFolder_Click" Background="#64748B"/>
                    </Grid>

                    <!-- Connection string -->
                    <TextBlock x:Name="lblCs" Text="Connection string" FontWeight="SemiBold" FontSize="12"
                               Foreground="#374151" Margin="0,14,0,4" Visibility="Collapsed"/>
                    <Grid x:Name="csGrid" Visibility="Collapsed">
                        <TextBox x:Name="txtCs" Padding="7,5" FontSize="12"
                                 BorderBrush="#D1D5DB" TextWrapping="Wrap"
                                 TextChanged="TxtCs_TextChanged"/>
                        <TextBlock x:Name="hintCs" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Margin="9,0,0,0"
                                   Foreground="#9CA3AF" FontSize="11" FontStyle="Italic"/>
                    </Grid>

                    <!-- Import options -->
                    <CheckBox x:Name="chkImportFks" Tag="CHK_IMPORT_FKS"
                              Content="Import foreign keys (if supported by backend)"
                              IsChecked="True" Margin="0,18,0,0"
                              ToolTip="When checked, foreign key constraints are read from the source database and saved as Relations in Blueprint."/>
                </StackPanel>

                <!-- Page 3: Import progress (Grid so ListBox can expand) -->
                <Grid x:Name="page3" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="lblImportTitle" Text="Importing schema…"
                               FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" x:Name="lblImportSub"
                               Text="Reading tables and columns from the selected database."
                               TextWrapping="Wrap" Foreground="#6B7280" FontSize="12" Margin="0,0,0,10"/>
                    <ProgressBar Grid.Row="2" x:Name="progressBar" Height="8"
                                 Minimum="0" Maximum="100" Foreground="#3B82F6"
                                 Background="#E5E7EB" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="3" x:Name="lstLog" FontSize="11" Foreground="#374151"
                             BorderBrush="#E5E7EB" Margin="0,0,0,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    <Border Grid.Row="4" x:Name="pnlSummary" Visibility="Collapsed"
                            Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1"
                            CornerRadius="4" Padding="12,8">
                        <TextBlock x:Name="lblSummary" FontSize="12" Foreground="#166534"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Grid>

            <!-- Navigation buttons -->
            <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left"
                            Width="80" Click="BtnCancel_Click" Background="#64748B"
                            ToolTip="Cancel and close this wizard"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnBack" Content="← Back" Width="80" Margin="0,0,8,0"
                                IsEnabled="False" Click="BtnBack_Click" Background="#475569"
                                ToolTip="Go back to the previous step"/>
                        <Button x:Name="btnNext" Content="Next →" Width="90" Click="BtnNext_Click" Background="#2563EB"
                                ToolTip="Proceed to the next step"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
