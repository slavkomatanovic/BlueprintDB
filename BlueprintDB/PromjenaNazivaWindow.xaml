<Window x:Class="Blueprint.App.PromjenaNazivaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Tag="FORM_PROMJENA_NAZIVA"
        Title="Rename Tables" Height="480" Width="680"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Program filter -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Label Content="Program:" Tag="LBL_PROGRAM" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbProgrami" Width="250" DisplayMemberPath="Nazivprograma"
                      SelectedValuePath="Idprograma" SelectionChanged="CbProgrami_SelectionChanged"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="dgPromjena" Grid.Row="1"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                  SelectionChanged="DgPromjena_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="[HDR_ID]"          Binding="{Binding Id}"               Width="50"/>
                <DataGridTextColumn Header="[HDR_STARI_NAZIV]" Binding="{Binding Starinazivtabele}" Width="*"/>
                <DataGridTextColumn Header="[HDR_NOVI_NAZIV]"  Binding="{Binding Novinazivtabele}"  Width="*"/>
                <DataGridTextColumn Header="[HDR_VERZIJA]"     Binding="{Binding Verzija}"          Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Forma -->
        <GroupBox Grid.Row="2" Header="Add / Edit" Tag="GRP_UNOS_IZMJENA" Margin="0,6,0,6">
            <Grid Margin="6,4,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <Label Content="Old name:" Tag="LBL_STARI_NAZIV" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbStariNaziv" Grid.Column="1" Margin="0,3,8,3" Height="26"
                          IsEditable="True"/>
                <Label Content="New name:" Tag="LBL_NOVI_NAZIV" Grid.Column="2" VerticalAlignment="Center"/>
                <TextBox x:Name="txtNoviNaziv" Grid.Column="3" Margin="0,3,8,3" Padding="3"/>
                <Label Content="Version:" Tag="LBL_VERZIJA" Grid.Column="4" VerticalAlignment="Center"/>
                <TextBox x:Name="txtVerzija" Grid.Column="5" Margin="0,3,0,3" Padding="3"/>
            </Grid>
        </GroupBox>

        <!-- Dugmad -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="New"    Tag="CMD_NOVI"    Width="80" Margin="4,0" Click="BtnNovi_Click"    Background="#1E3A5F"/>
            <Button Content="Save"   Tag="CMD_SACUVAJ" Width="80" Margin="4,0" Click="BtnSacuvaj_Click" Background="#15803D"/>
            <Button Content="Delete" Tag="CMD_OBRISI"  Width="80" Margin="4,0" Click="BtnObrisi_Click"  Background="#DC2626"/>
            <Button Content="Close"  Tag="CMD_ZATVORI" Width="80" Margin="4,0" Click="BtnZatvori_Click" Background="#475569"/>
        </StackPanel>
    </Grid>
</Window>
