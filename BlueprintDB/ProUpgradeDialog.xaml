<Window x:Class="Blueprint.App.ProUpgradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blueprint Pro"
        Width="460" Height="340"
        MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Blueprint Pro" Foreground="White"
                                   FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="One-time purchase · No subscription" Foreground="#94A3B8"
                                   FontSize="10"/>
                    </StackPanel>
                </StackPanel>
                <Border Background="#F59E0B" CornerRadius="4" Padding="10,4"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="$49" Foreground="White" FontSize="18"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="24,18,24,0">

            <TextBlock Text="What you unlock with Pro:" FontSize="11" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,10"/>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="11" Foreground="#16A34A" Margin="0,1,8,0"/>
                    <TextBlock FontSize="12" Foreground="#1E3A5F">
                        <Run FontWeight="SemiBold">All 10 backends</Run>
                        <Run>— MySQL, PostgreSQL, SQL Server, Oracle, DB2, Firebird, DBase</Run>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="11" Foreground="#16A34A" Margin="0,1,8,0"/>
                    <TextBlock FontSize="12" Foreground="#1E3A5F">
                        <Run FontWeight="SemiBold">Unlimited Transfer Data Wizard</Run>
                        <Run>runs (5 free included)</Run>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="11" Foreground="#16A34A" Margin="0,1,8,0"/>
                    <TextBlock FontSize="12" Foreground="#1E3A5F">
                        <Run FontWeight="SemiBold">Schema Export as SQL</Run>
                        <Run>— generate DDL scripts for any backend</Run>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="11" Foreground="#16A34A" Margin="0,1,8,0"/>
                    <TextBlock FontSize="12" Foreground="#1E3A5F">
                        <Run FontWeight="SemiBold">Lifetime license</Run>
                        <Run>— one machine, all future updates</Run>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" x:Name="btnBuy" Content="Buy Pro  →"
                        Width="110" Margin="0,0,8,0"
                        Background="#F59E0B" Foreground="White"
                        FontWeight="SemiBold" Padding="0,7"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnBuy_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#D97706"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" x:Name="btnEnterKey" Content="Enter License Key"
                        Width="130"
                        Background="#1D4ED8" Foreground="White"
                        FontWeight="SemiBold" Padding="0,7"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnEnterKey_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
