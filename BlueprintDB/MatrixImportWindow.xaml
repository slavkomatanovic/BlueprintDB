<Window x:Class="Blueprint.App.MatrixImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Tag="FORM_MATRIX_IMPORT"
        Title="Matrix Import" Height="560" Width="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1E3A5F">
            <StackPanel Margin="0,28,0,0">
                <TextBlock Text="&#xECC4;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           HorizontalAlignment="Center" Foreground="#60A5FA" Margin="0,0,0,6"/>
                <TextBlock Text="Blueprint" FontSize="16" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock FontSize="10" Foreground="#93C5FD" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Padding="14,4,14,24"
                           Text="Matrix Import"/>

                <Border Background="#122A47" Margin="12,0" CornerRadius="6" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="Format" Foreground="#60A5FA" FontSize="10"
                                   FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Foreground="#CBD5E1" FontSize="10" TextWrapping="Wrap"
                                   Text="msaccess-vcs-addin export folder (tables/*.txt)"/>
                        <TextBlock Foreground="#CBD5E1" FontSize="10" TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Text="Types are stored as ADO names (adWChar, adLong…) — imported directly."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Margin="16,16,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Folder picker -->
            <GroupBox Grid.Row="0" Header="Matrix export folder" Tag="GRP_MATRIX_FOLDER" Margin="0,0,0,8">
                <Grid Margin="6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtFolder" Grid.Column="0" IsReadOnly="True"
                             VerticalAlignment="Center" Padding="4,3"
                             Text="(select the folder that contains Programi.txt, Tabele.txt, Kolone.txt)"/>
                    <Button x:Name="btnBrowse" Grid.Column="2" Content="Browse…"
                            Tag="BTN_BROWSE" Width="76" Click="BtnBrowse_Click"/>
                </Grid>
            </GroupBox>

            <!-- Preview summary -->
            <GroupBox Grid.Row="1" Header="Preview" Tag="GRP_PREVIEW" Margin="0,0,0,8">
                <Grid Margin="6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock x:Name="lblProgCount" Text="—" FontSize="24" FontWeight="Bold"
                                   Foreground="#1E40AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Programs" FontSize="10" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Tag="LBL_PROGRAMS"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock x:Name="lblTblCount" Text="—" FontSize="24" FontWeight="Bold"
                                   Foreground="#1E40AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Tables" FontSize="10" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Tag="LBL_TABLES"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock x:Name="lblColCount" Text="—" FontSize="24" FontWeight="Bold"
                                   Foreground="#1E40AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Columns" FontSize="10" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Tag="LBL_COLUMNS"/>
                    </StackPanel>
                    <Button x:Name="btnPreview" Grid.Column="3" Content="Preview"
                            Tag="BTN_PREVIEW" Width="76" IsEnabled="False" Click="BtnPreview_Click"
                            VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>

            <!-- Conflict strategy -->
            <GroupBox Grid.Row="2" Header="If program/table/column already exists" Tag="GRP_CONFLICT" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Margin="6,6">
                    <RadioButton x:Name="rbSkip" Content="Skip (keep existing)"
                                 Tag="RB_SKIP" IsChecked="True" Margin="0,0,16,0"/>
                    <RadioButton x:Name="rbOverwrite" Content="Overwrite (update names)"
                                 Tag="RB_OVERWRITE"/>
                </StackPanel>
            </GroupBox>

            <!-- Log -->
            <ScrollViewer Grid.Row="3" x:Name="logScroll"
                          VerticalScrollBarVisibility="Auto"
                          Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                          Margin="0,0,0,8">
                <TextBlock x:Name="txtLog" Padding="8" FontFamily="Consolas" FontSize="11"
                           TextWrapping="Wrap" Foreground="#374151"/>
            </ScrollViewer>

            <!-- Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblStatus" Grid.Column="0" VerticalAlignment="Center"
                           FontSize="11" Foreground="#6B7280"/>
                <Button x:Name="btnImport" Grid.Column="2" Content="Import"
                        Tag="BTN_IMPORT" Width="90" IsEnabled="False" Click="BtnImport_Click"/>
                <Button x:Name="btnClose" Grid.Column="4" Content="Close"
                        Tag="BTN_CLOSE" Width="76" Click="BtnClose_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
