<UserControl x:Class="Blueprint.App.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F9FAFB">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">

            <!-- ── Update Available banner (hidden until update check returns) ── -->
            <Border x:Name="pnlUpdate"
                    Background="#EFF6FF" BorderBrush="#93C5FD" BorderThickness="1"
                    CornerRadius="8" Padding="18,14" Margin="0,0,0,18"
                    Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="#2563EB"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="lblUpdateTitle" Text="Update Available"
                                   FontWeight="SemiBold" FontSize="13" Foreground="#1E3A8A"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="lblUpdateBody" TextWrapping="Wrap" MaxWidth="420"
                               Foreground="#1E40AF" FontSize="11" LineHeight="18" Margin="0,0,0,10"
                               Text="A new version of Blueprint is available."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnDownloadUpdate"
                                Content="&#x2193;  Download Update"
                                HorizontalAlignment="Left"
                                Padding="12,5" FontSize="11"
                                Click="BtnDownloadUpdate_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="#2563EB"/>
                                    <Setter Property="Foreground"      Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding"         Value="12,5"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="1" Content="Skip this version"
                                HorizontalAlignment="Right"
                                Padding="10,5" FontSize="11"
                                Click="BtnSkipUpdate_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="#1E40AF"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush"     Value="#93C5FD"/>
                                    <Setter Property="Padding"         Value="10,5"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Getting Started banner (hidden once a program exists) ───── -->
            <Border x:Name="pnlGetStarted"
                    Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                    CornerRadius="8" Padding="18,14" Margin="0,0,0,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="#D97706"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Getting Started" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#92400E"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" MaxWidth="420" Foreground="#78350F"
                               FontSize="11" LineHeight="18" Margin="0,0,0,10">
                        No programs found yet. Blueprint works by importing your
                        database schema (tables, columns, relations) into its
                        metadata store — then you can sync, transfer, and manage
                        structure across multiple backends.
                        <LineBreak/>
                        <LineBreak/>
                        Click <Bold>Schema Import</Bold> in the Wizards strip below
                        to connect to your database and get started.
                    </TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="btnGetStarted"
                                Content="→  Open Schema Import Wizard"
                                HorizontalAlignment="Left"
                                Padding="12,5" FontSize="11"
                                Click="BtnGetStarted_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="#D97706"/>
                                    <Setter Property="Foreground"      Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding"         Value="12,5"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#B45309"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="1" Content="✕ Dismiss"
                                HorizontalAlignment="Right"
                                Padding="10,5" FontSize="11"
                                Click="BtnDismissGetStarted_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="#92400E"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush"     Value="#FCD34D"/>
                                    <Setter Property="Padding"         Value="10,5"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Wizard strip ──────────────────────────────────────────────── -->
            <Border Background="#EEF2FF" CornerRadius="10" Padding="20,14" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="W I Z A R D S" FontSize="9" FontWeight="Bold"
                               Foreground="#6366F1" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <WrapPanel HorizontalAlignment="Center">

                        <!-- Schema Import Wizard — amber -->
                        <Button Style="{StaticResource ToolBtn}" Click="BtnWizard_Click"
                                ToolTip="Read an existing database and import its tables and columns into Blueprint's metadata store.">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="28" HorizontalAlignment="Center"
                                           Foreground="#D97706"/>
                                <TextBlock Tag="BTN_WIZARD" Text="Schema Import" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"
                                           Foreground="#374151"/>
                            </StackPanel>
                        </Button>

                        <!-- Transfer Data Wizard — cyan -->
                        <Button Style="{StaticResource ToolBtn}" Click="BtnTransferWizard_Click"
                                ToolTip="Copy data rows from one database to another, mapping tables and columns across different backends.">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="28" HorizontalAlignment="Center"
                                           Foreground="#0891B2"/>
                                <TextBlock Tag="BTN_TRANSFER_WIZARD" Text="Transfer Wizard" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"
                                           Foreground="#374151"/>
                            </StackPanel>
                        </Button>

                        <!-- Schema Sync Wizard — violet -->
                        <Button Style="{StaticResource ToolBtn}" Click="BtnSchemaSyncWizard_Click"
                                ToolTip="Compare Blueprint's stored schema against a live database and apply missing tables, columns, and FK constraints.">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="28" HorizontalAlignment="Center"
                                           Foreground="#7C3AED"/>
                                <TextBlock Tag="BTN_SCHEMA_SYNC" Text="Schema Sync" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,5,0,0"
                                           Foreground="#374151"/>
                            </StackPanel>
                        </Button>

                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ── Regular tools ─────────────────────────────────────────────── -->
            <WrapPanel HorizontalAlignment="Center">

                <!-- Programs — blue -->
                <Button Style="{StaticResource ToolBtn}" Click="BtnProgrami_Click"
                        ToolTip="Add, edit, or delete programs. Each program groups a set of tables and relations.">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="28" HorizontalAlignment="Center"
                                   Foreground="#1D4ED8"/>
                        <TextBlock Tag="BTN_PROGRAMI" Text="Programs" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="#374151"/>
                    </StackPanel>
                </Button>

                <!-- Tables — green -->
                <Button Style="{StaticResource ToolBtn}" Click="BtnTabele_Click"
                        ToolTip="Browse and edit tables and columns for the currently selected program.">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="28" HorizontalAlignment="Center"
                                   Foreground="#059669"/>
                        <TextBlock Tag="BTN_TABELE" Text="Tables" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="#374151"/>
                    </StackPanel>
                </Button>

                <!-- Design — indigo -->
                <Button Style="{StaticResource ToolBtn}" Click="BtnKonfiguracija_Click"
                        ToolTip="Select a program and a backend database, then launch Schema Sync to align them.">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B8;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="28" HorizontalAlignment="Center"
                                   Foreground="#6366F1"/>
                        <TextBlock Tag="MENU_KONFIGURACIJA" Text="Setup" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="#374151"/>
                    </StackPanel>
                </Button>

                <!-- Exit — red -->
                <Button Style="{StaticResource ToolBtnDanger}" Click="BtnKraj_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="28" HorizontalAlignment="Center"
                                   Foreground="#DC2626"/>
                        <TextBlock Tag="BTN_KRAJ" Text="Exit" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="#374151"/>
                    </StackPanel>
                </Button>

            </WrapPanel>
        </StackPanel>
    </Grid>
</UserControl>
